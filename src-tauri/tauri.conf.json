{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Veloce",
    "version": "1.10.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": false,
        "copyFile": true,
        "createDir": true,
        "readDir": true,
        "removeFile": true,
        "renameFile": true,
        "scope": ["**"]
      },
      "path": {
        "all": true
      },
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "open": true
      },
      "protocol": {
        "all": false,
        "asset": true,
        "assetScope": [
          "**",
          "$LOCALDATA/**",
          "$APPDATA/**",
          "C:/**",
          "D:/**",
          "E:/**",
          "F:/**"
        ]
      },
      "window": {
        "all": false,
        "close": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "setFullscreen": true,
        "setPosition": true,
        "setSize": true,
        "startDragging": true
      }
    },
    "windows": [
      {
        "title": "Veloce",
        "width": 800,
        "height": 600,
        "fileDropEnabled": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": true,
      "csp": "default-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' asset: veloce: http://asset.localhost https://asset.localhost http://veloce.localhost https://veloce.localhost http://127.0.0.1:* http://localhost:* data: blob:; media-src 'self' asset: http://asset.localhost https://asset.localhost http://127.0.0.1:* http://localhost:*;"
    },
    "bundle": {
      "active": false,
      "targets": "all",
      "identifier": "com.matsumotoswitch.veloce",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
